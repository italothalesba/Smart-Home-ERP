rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Specific Validations ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'quantity']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.quantity is number && data.quantity >= 0;
    }

    function isValidFinance(data) {
      return data.keys().hasAll(['description', 'type', 'value']) &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 200 &&
             data.type in ['fixa', 'parcelado', 'extra', 'renegociacao'] &&
             data.value is number &&
             (!data.keys().contains('ownerId') || data.ownerId == request.auth.uid) &&
             (!data.keys().contains('status') || data.status in ['pendente', 'pago']);
    }

    function isValidIncome(data) {
      return data.keys().hasAll(['description', 'value', 'type']) &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 200 &&
             data.value is number &&
             data.type in ['fixo', 'volatil'] &&
             (!data.keys().contains('ownerId') || data.ownerId == request.auth.uid);
    }

    function isValidMeal(data) {
      return data.keys().hasAll(['day', 'type', 'title']) &&
             data.day is string && data.type in ['cafe', 'almoco', 'lanche', 'jantar'] &&
             data.title is string && data.title.size() <= 150;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             (!data.keys().contains('budget') || data.budget is number);
    }

    function isValidMarketItem(data) {
      return data.keys().hasAll(['productId', 'name', 'quantity']) &&
             data.productId is string &&
             data.name is string &&
             data.quantity is number;
    }

    // --- Collection Matches ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'budget']);

      match /products/{productId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidProduct(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'quantity', 'category', 'unit', 'minStock', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /finances/{financeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(financeId) && isValidFinance(incoming());
        allow update: if isOwner(userId) && isValidFinance(incoming());
        allow delete: if isOwner(userId);
      }

      match /incomes/{incomeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(incomeId) && isValidIncome(incoming());
        allow update: if isOwner(userId) && isValidIncome(incoming());
        allow delete: if isOwner(userId);
      }

      match /meals/{mealId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(mealId) && isValidMeal(incoming());
        allow update: if isOwner(userId) && isValidMeal(incoming());
        allow delete: if isOwner(userId);
      }

      match /pets/{petId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(petId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /market_items/{itemId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(itemId) && isValidMarketItem(incoming());
        allow update: if isOwner(userId) && isValidMarketItem(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
